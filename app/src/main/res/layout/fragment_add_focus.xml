<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_slate_surface">

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back"
                    android:contentDescription="Back"
                    android:tint="@color/zen_slate_dark" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ZenZone"
                    android:textColor="@color/zen_slate_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_font_family"
                    android:gravity="center" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_lotus_logo"
                    android:contentDescription="Lotus logo"
                    app:tint="@color/zen_teal_primary" />

            </LinearLayout>

            <!-- Title Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_font_family"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="@color/zen_slate_dark"
                    android:lineSpacingExtra="4dp"
                    android:text="Define Your Focus" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/poppins_font_family"
                    android:text="Create a sacred space for your intentions. Small steps lead to vast landscapes of growth."
                    android:textColor="@color/zen_gray_text"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

            <!-- Form Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <!-- Focus Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FOCUS NAME"
                    android:textColor="@color/zen_gray_text"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_font_family"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_focus_name"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:boxBackgroundColor="#F0F4F8"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_focus_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="e.g., Deep Reading"
                        android:textColorHint="#A0AEC0"
                        android:textColor="@color/zen_slate_dark"
                        android:fontFamily="@font/poppins_font_family"
                        android:inputType="text"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Target Duration -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TARGET DURATION"
                    android:textColor="@color/zen_gray_text"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_font_family"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#F0F4F8"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <EditText
                        android:id="@+id/et_target_minutes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:text="40"
                        android:textColor="@color/zen_slate_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/poppins_font_family"
                        android:inputType="number"
                        android:paddingVertical="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="minutes"
                        android:textColor="@color/zen_gray_text"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_font_family" />

                </LinearLayout>

                <!-- Frequency -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FREQUENCY"
                    android:textColor="@color/zen_gray_text"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_font_family"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggle_frequency"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_daily"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Daily"
                        android:textColor="@color/zen_slate_dark"
                        android:fontFamily="@font/poppins_font_family"
                        android:paddingVertical="12dp"
                        app:strokeColor="@color/zen_teal_primary"
                        app:strokeWidth="2dp"
                        app:cornerRadius="8dp"
                        android:checked="true" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_weekly"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Weekly"
                        android:textColor="@color/zen_gray_text"
                        android:fontFamily="@font/poppins_font_family"
                        android:paddingVertical="12dp"
                        app:strokeColor="#E2E8F0"
                        app:strokeWidth="1dp"
                        app:cornerRadius="8dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>

                <!-- Inspirational Quote Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="32dp"
                    app:cardBackgroundColor="#F0F4F8"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_lotus_logo"
                            android:contentDescription="Wisdom icon"
                            app:tint="@color/zen_teal_primary"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_quote"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="&quot;The secret of getting ahead is getting started.&quot;"
                                android:textColor="@color/zen_slate_dark"
                                android:textSize="13sp"
                                android:fontFamily="@font/poppins_font_family"
                                android:textStyle="italic"
                                android:lineSpacingExtra="2dp"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_quote_author"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DAILY WISDOM"
                                android:textColor="@color/zen_gray_text"
                                android:textSize="10sp"
                                android:fontFamily="@font/poppins_font_family"
                                android:letterSpacing="0.08" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Create Goal Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_create_goal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Goal"
                    android:textColor="@color/zen_slate_surface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_font_family"
                    android:paddingVertical="16dp"
                    android:backgroundTint="@color/zen_teal_primary"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="24dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
