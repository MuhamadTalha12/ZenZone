<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/zen_slate_bg"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your Achievements"
        android:textColor="@color/zen_slate_dark"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_font_family"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Keep focusing to unlock more milestones"
        android:textColor="@color/zen_gray_text"
        android:textSize="14sp"
        android:fontFamily="@font/poppins_font_family"
        android:layout_marginBottom="24dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_badges_all"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_close_badges"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="CLOSE"
        android:textColor="@color/zen_slate_surface"
        android:backgroundTint="@color/zen_teal_primary"
        app:cornerRadius="12dp" />

</LinearLayout>