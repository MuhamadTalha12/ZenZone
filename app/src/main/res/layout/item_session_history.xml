<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="16dp"
    android:gravity="center_vertical">

    <!-- Icon Circle -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardBackgroundColor="@color/zen_slate_dark"
        app:cardElevation="0dp"
        app:cardCornerRadius="8dp">

        <ImageView
            android:id="@+id/iv_session_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_focus"
            app:tint="@color/zen_slate_surface" />

    </androidx.cardview.widget.CardView>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_session_goal_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deep Focus Work"
            android:textColor="@color/zen_slate_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_font_family"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_session_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today • 2:15 PM"
            android:textColor="@color/zen_gray_text"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_font_family" />

    </LinearLayout>

    <!-- Duration and Efficiency -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tv_session_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="45 min"
            android:textColor="@color/zen_slate_dark"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_font_family"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_efficiency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#E8F5E9"
            app:cardElevation="0dp"
            app:cardCornerRadius="8dp">

            <TextView
                android:id="@+id/tv_efficiency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Efficiency\n92%"
                android:textColor="#2E7D32"
                android:textSize="9sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_font_family"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:lineSpacingMultiplier="1.1" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>
