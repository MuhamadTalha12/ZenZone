<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_slate_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/zen_teal_primary"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="28dp">

            <!-- Avatar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardBackgroundColor="@color/zen_slate_surface"
                app:cardCornerRadius="40dp"
                app:cardElevation="4dp">

                <TextView
                    android:id="@+id/tv_avatar_initial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:fontFamily="@font/poppins_font_family"
                    android:text="Z"
                    android:textColor="@color/zen_teal_primary"
                    android:textSize="32sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Name -->
            <TextView
                android:id="@+id/tv_zen_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Zen Practitioner"
                android:fontFamily="@font/poppins_font_family"
                android:textColor="@color/zen_slate_surface"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Level -->
            <TextView
                android:id="@+id/tv_zen_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:alpha="0.85"
                android:fontFamily="@font/poppins_font_family"
                android:text="Level 1 · Digital Monk"
                android:textColor="@color/zen_slate_surface"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- XP Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-20dp"
            app:cardBackgroundColor="@color/zen_slate_surface"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_xp_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Zen Level 1"
                        android:fontFamily="@font/poppins_font_family"
                        android:textColor="@color/zen_slate_dark"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_xp_caption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 100 XP"
                        android:fontFamily="@font/poppins_font_family"
                        android:textColor="@color/zen_gray_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pb_xp_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="10dp"
                    android:progressDrawable="@drawable/custom_progress_bar" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Badges Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Zen Badges"
                android:fontFamily="@font/poppins_font_family"
                android:textColor="@color/zen_slate_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_badge_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/zen_teal_light"
                android:fontFamily="@font/poppins_font_family"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="0/8"
                android:textColor="@color/zen_teal_dark"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Badges Grid -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/zen_slate_surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <GridLayout
                android:id="@+id/grid_badges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:padding="12dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
