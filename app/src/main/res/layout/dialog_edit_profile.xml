<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/zen_slate_dark"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="32dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#4DFFFFFF" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_font_family"
        android:text="Edit Profile"
        android:textColor="@color/zen_slate_surface"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Profile Image Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_font_family"
        android:text="Profile Picture"
        android:textColor="@color/zen_teal_light"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardBackgroundColor="@color/zen_slate_surface"
            app:cardCornerRadius="60dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/iv_profile_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile"
                android:alpha="0.5"
                android:contentDescription="@string/profile_picture_preview" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <!-- Image Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_image"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/poppins_font_family"
            android:text="Select Image"
            android:textColor="@color/zen_teal_light"
            app:strokeColor="@color/zen_teal_light"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:textSize="12sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_remove_image"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:fontFamily="@font/poppins_font_family"
            android:text="Remove"
            android:textColor="@color/zen_danger_red"
            app:strokeColor="@color/zen_danger_red"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_name"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:hint="Display Name"
        app:hintTextColor="@color/zen_teal_light"
        app:boxStrokeColor="@color/zen_teal_light"
        app:boxStrokeWidth="1dp"
        app:boxBackgroundColor="#1AFFFFFF">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_profile_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_font_family"
            android:inputType="textPersonName|textCapWords"
            android:textColor="@color/zen_slate_surface"
            android:textColorHint="#80FFFFFF"
            android:maxLength="30" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/poppins_font_family"
            android:paddingVertical="14dp"
            android:text="Cancel"
            android:textColor="@color/zen_slate_surface"
            app:strokeColor="@color/zen_slate_surface"
            app:strokeWidth="1dp"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="@color/zen_teal_primary"
            android:fontFamily="@font/poppins_font_family"
            android:paddingVertical="14dp"
            android:text="Save"
            android:textColor="@color/zen_slate_surface"
            android:textStyle="bold"
            app:cornerRadius="14dp" />
    </LinearLayout>

</LinearLayout>
