<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_badge"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/zen_slate_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:id="@+id/ll_badge_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="12dp">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">

            <ImageView
                android:id="@+id/iv_badge_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lotus_logo"
                app:tint="@color/zen_teal_primary" />

            <ImageView
                android:id="@+id/iv_badge_lock"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="@color/zen_gray_text"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_badge_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins_font_family"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:text="BADGE NAME"
            android:textColor="@color/zen_slate_dark"
            android:textSize="9sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_badge_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_font_family"
            android:gravity="center"
            android:text="Description goes here"
            android:textColor="@color/zen_gray_text"
            android:textSize="9sp"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
