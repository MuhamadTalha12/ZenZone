<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="20dp"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tv_app_logo_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="🧘 ZenZone"
        android:fontFamily="@font/poppins_font_family"
        android:textColor="@color/zen_slate_dark"
        android:textSize="20sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/iv_common_info"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_info"
        app:tint="@color/zen_slate_dark"
        android:contentDescription="Information"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_common_profile_mini"
        android:layout_width="32dp"
        android:layout_height="32dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/zen_teal_primary"
        app:cardElevation="2dp"
        android:clickable="true"
        android:focusable="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/tv_common_profile_initial_mini"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Z"
                android:textColor="@color/zen_slate_surface"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_font_family" />

            <ImageView
                android:id="@+id/iv_common_profile_image_mini"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Profile Picture" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
