<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/zen_slate_surface"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Badge Icon Container -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F4F3">
                
                <ImageView
                    android:id="@+id/iv_badge_list_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="14dp"
                    android:src="@drawable/ic_lotus_logo"
                    android:contentDescription="@string/badge_icon" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Lock overlay for locked badges -->
            <ImageView
                android:id="@+id/iv_badge_list_lock"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                android:visibility="gone"
                android:contentDescription="@string/locked_badge" />
        </FrameLayout>

        <!-- Badge Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_badge_list_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_font_family"
                android:textColor="@color/zen_slate_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="Badge Name" />

            <TextView
                android:id="@+id/tv_badge_list_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_font_family"
                android:textColor="@color/zen_gray_text"
                android:textSize="12sp"
                android:text="Badge description goes here" />

            <TextView
                android:id="@+id/tv_badge_list_requirement"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/poppins_font_family"
                android:textColor="@color/zen_teal_primary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="Requirement" />
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
