<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_slate_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Common Navigation Bar -->
            <include layout="@layout/layout_common_navbar" />

            <!-- Active Session Badge -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_active_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/zen_teal_light"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:gravity="center">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/ic_focus" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACTIVE SESSION"
                        android:fontFamily="@font/poppins_font_family"
                        android:textColor="@color/zen_teal_dark"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Goal Name Title -->
            <TextView
                android:id="@+id/tv_goal_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="Select a Goal"
                android:fontFamily="@font/poppins_font_family"
                android:textColor="@color/zen_slate_dark"
                android:textSize="36sp"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Goal Subtitle -->
            <TextView
                android:id="@+id/tv_goal_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:text="Choose your focus goal below"
                android:fontFamily="@font/poppins_font_family"
                android:textColor="@color/zen_gray_text"
                android:textSize="16sp"
                android:gravity="center" />

            <!-- Goal Selector (Hidden when running) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_goal_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/zen_slate_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Focus Goal"
                        android:fontFamily="@font/poppins_font_family"
                        android:textColor="@color/zen_slate_dark"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinner_goal_selector"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="#F0F4F8"
                        android:popupBackground="@color/zen_slate_surface"
                        android:spinnerMode="dropdown"
                        android:paddingHorizontal="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Timer View -->
            <com.zenzone.app.ui.focus.CircularTimerView
                android:id="@+id/timer_view"
                android:layout_width="320dp"
                android:layout_height="320dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="40dp" />

            <!-- Complete Session Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_complete"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="40dp"
                android:layout_marginTop="40dp"
                android:backgroundTint="@color/zen_teal_primary"
                android:fontFamily="@font/poppins_font_family"
                android:text="Complete Session"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/zen_slate_surface"
                android:visibility="gone"
                app:cornerRadius="32dp"
                app:icon="@drawable/ic_focus"
                app:iconGravity="end"
                app:iconPadding="12dp"
                app:iconTint="@color/zen_slate_surface" />

            <!-- Start Button (shown when not running) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginHorizontal="40dp"
                android:layout_marginTop="40dp"
                android:backgroundTint="@color/zen_teal_primary"
                android:fontFamily="@font/poppins_font_family"
                android:text="Start Focus Session"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/zen_slate_surface"
                app:cornerRadius="32dp"
                app:icon="@drawable/ic_focus"
                app:iconGravity="start"
                app:iconPadding="12dp"
                app:iconTint="@color/zen_slate_surface" />

            <!-- Control Buttons (Pause & Cancel) -->
            <LinearLayout
                android:id="@+id/ll_control_buttons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <!-- Pause Button -->
                <LinearLayout
                    android:id="@+id/btn_pause_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="40dp"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardBackgroundColor="@color/zen_slate_surface"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="2dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="⏸"
                            android:textSize="24sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="PAUSE"
                        android:fontFamily="@font/poppins_font_family"
                        android:textColor="@color/zen_gray_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                </LinearLayout>

                <!-- Cancel Button -->
                <LinearLayout
                    android:id="@+id/btn_cancel_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardBackgroundColor="@color/zen_slate_surface"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="2dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="✕"
                            android:textSize="24sp"
                            android:textColor="@color/zen_danger_red" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="CANCEL"
                        android:fontFamily="@font/poppins_font_family"
                        android:textColor="@color/zen_gray_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                </LinearLayout>
            </LinearLayout>

            <!-- Motivational Quote -->
            <TextView
                android:id="@+id/tv_quote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="40dp"
                android:layout_marginHorizontal="40dp"
                android:text="&quot;The secret of getting ahead is getting started.&quot;"
                android:fontFamily="@font/poppins_font_family"
                android:textColor="@color/zen_gray_text"
                android:textSize="14sp"
                android:fontStyle="italic"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <!-- DND and Focus Lock Badges -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_dnd_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@color/zen_teal_dark"
                    android:fontFamily="@font/poppins_font_family"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="🔕 DND"
                    android:textColor="@color/zen_slate_surface"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_focus_lock_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/zen_danger_red"
                    android:fontFamily="@font/poppins_font_family"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="🔒 Locked"
                    android:textColor="@color/zen_slate_surface"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/zen_teal_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
