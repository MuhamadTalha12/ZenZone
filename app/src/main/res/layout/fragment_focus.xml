<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zen_slate_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Goal Selector Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_goal_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/zen_teal_primary"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Focus Goal"
                        android:fontFamily="@font/poppins_font_family"
                        android:textColor="@color/zen_slate_surface"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <!-- Styled Spinner Container -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#33FFFFFF"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp">

                        <Spinner
                            android:id="@+id/spinner_goal_selector"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:popupBackground="@color/zen_slate_dark"
                            android:spinnerMode="dropdown" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_goal_info_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/poppins_font_family"
                        android:text="Target: 25 minutes"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Timer View -->
            <com.zenzone.app.ui.focus.CircularTimerView
                android:id="@+id/timer_view"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_marginTop="32dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cv_goal_selector" />

            <!-- Control Buttons -->
            <LinearLayout
                android:id="@+id/ll_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/timer_view">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="@color/zen_teal_primary"
                    android:fontFamily="@font/poppins_font_family"
                    android:text="Start"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_focus"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_stop"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="@color/zen_danger_red"
                    android:fontFamily="@font/poppins_font_family"
                    android:text="Stop"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="14dp" />
            </LinearLayout>

            <!-- DND Badge -->
            <TextView
                android:id="@+id/tv_dnd_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@color/zen_teal_dark"
                android:fontFamily="@font/poppins_font_family"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="🔕 DND Active"
                android:textColor="@color/zen_slate_surface"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ll_buttons" />

            <!-- Focus Lock Badge -->
            <TextView
                android:id="@+id/tv_focus_lock_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@color/zen_danger_red"
                android:fontFamily="@font/poppins_font_family"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="🔒 Focus Lock Active"
                android:textColor="@color/zen_slate_surface"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_dnd_badge" />

            <!-- Session Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_session_goal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/zen_slate_surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/tv_focus_lock_badge">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_goal_info_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Session Goal: Select a goal"
                        android:fontFamily="@font/poppins_font_family"
                        android:textStyle="bold"
                        android:textColor="@color/zen_slate_dark"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/poppins_font_family"
                        android:text="💡 Tip: Stay focused and build your chain!"
                        android:textColor="@color/zen_gray_text"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Manual Log Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_log_manual"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="80dp"
                android:fontFamily="@font/poppins_font_family"
                android:text="Log Manual Session"
                android:textColor="@color/zen_teal_primary"
                app:cornerRadius="12dp"
                app:strokeColor="@color/zen_teal_primary"
                app:strokeWidth="2dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cv_session_goal" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Info FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="How to earn XP and badges"
        android:src="@drawable/ic_info"
        app:backgroundTint="@color/zen_blue_muted"
        app:borderWidth="0dp"
        app:elevation="6dp"
        app:fabSize="normal"
        app:tint="@color/zen_slate_surface" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
